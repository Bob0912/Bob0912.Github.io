  <subtitle>如果提前了解了你所面对的人生，你是否还有勇气前来？</subtitle>
  <title>小Bob的博客</title>
  <updated>2026-06-28T17:10:44.479Z</updated>
  <entry>
    <author>
      <name>小Bob</name>
    </author>
    <category term="编程" scheme="https://dpw09.cn/categories/%E7%BC%96%E7%A8%8B/"/>
    <category term="工具链" scheme="https://dpw09.cn/categories/%E7%BC%96%E7%A8%8B/%E5%B7%A5%E5%85%B7%E9%93%BE/"/>
